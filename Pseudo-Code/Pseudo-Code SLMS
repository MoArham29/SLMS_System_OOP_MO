<pre>
Set today &lt;- 0
Create Library "library"

While true
    Display main menu
    Display "1. Login"
    Display "0. Exit"

    choice &lt;- Read input

    If choice = 0
        Stop program
    Endif

    If choice = 1
        username &lt;- Read input
        password &lt;- Read input

        result &lt;- library.loginUser(username, password)

        If login fails
            Display "Login failed."
            Continue
        Endif

        If role = Member
            Create Member object

            While logged in
                Display Member menu
                Read action

                If action = list books
                    Call library.listAllBooks(today)

                Else if action = search by title
                    Call library.searchByTitle(query)

                Else if action = search by author
                    Call library.searchByAuthor(query)

                Else if action = borrow
                    Call library.borrowBook(bookId, member, today)

                Else if action = return
                    Call library.returnBook(bookId, member, today)

                Else if action = reserve
                    Call library.reserveBook(bookId, member, today)

                Else if action = view borrowed books
                    Call library.getBorrowedBooksForMember(member.id)

                Else if action = advance day
                    today &lt;- today + 1

                Else if action = logout
                    Exit Member menu
                Endif
            Endwhile

        Else if role = Librarian
            Create Librarian object

            While logged in
                Display Librarian menu
                Read action

                If action = list books
                    Call library.listAllBooks(today)

                Else if action = add book
                    Call library.addBook(newBook, librarian)

                Else if action = remove book
                    Call library.removeBook(bookId, librarian)

                Else if action = overdue report
                    Call library.overdueReport(today)

                Else if action = create member account
                    Read member details
                    Call library.registerMember(userId, name, email, username, password)

                Else if action = advance day
                    today &lt;- today + 1

                Else if action = logout
                    Exit Librarian menu
                Endif
            Endwhile

        Else if role = Admin
            Create Admin object

            While logged in
                Display Admin menu
                Read action

                If action = set borrowing limit
                    Call library.setBorrowingLimit(limit, admin)

                Else if action = set late penalty
                    Call library.setLatePenalty(penalty, admin)

                Else if action = advance day
                    today &lt;- today + 1

                Else if action = logout
                    Exit Admin menu
                Endif
            Endwhile
        Endif
    Endif
Endwhile
</pre>