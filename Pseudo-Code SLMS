### 3.5 reserveBook(bookId, member, today)
```
Function reserveBook(bookId, member, today)

    book <- Find book in books where book.Id = bookId
    if book not found
         Display "Reservation Denied: book not found"
         Return false
    endif
    call book.refreshReservation(today)
    success <- book.reserve(member.id, today)

    if success = true
          Display "Reservation successful (expires after 3 days)
          Return true
    endif

    Display "Reservation Denied: book must be borrowed by another member"
    Return false

end Function
```

