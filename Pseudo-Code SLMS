### 3.3 borrowBook(bookId, member, today)

```
Function borrowBook(bookId, member, today) 
    
    if member.borrowedCount() >= borrowing.limit
         Display "Borrowing Denied: borrowing limit reached."
         Return false
    endif
    book <- Find book in books where book.Id = bookId
    if book Not found
        Display "Borrowing Denied: book not found."
        Return false
    endif
    call book.refreshReservation(today)
    if book.isAvailable() = false
        display " Borrowing Denied: book not Available."
        Return false
    endif
    success <- book.borrow(memberId, today, loaDays)
    if success = true
         call member.addBorrowed(bookId)
         Display "Borrowing Successful."
         Return true
    endif
    Return false
end Function
```

