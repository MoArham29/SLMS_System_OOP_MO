### 1.6 refreshReservation(today)

```
Function refreshReservation(today)

    if status = Reserved AND today > reservationExpiryDay
        reservedById <- ""
        reservationExpiryDay <- -1
 
        if borrowerId != ""
             status <- Borrowed
        else 
             status <- Available
        endif
    endif
end Function
